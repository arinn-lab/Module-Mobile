<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.songpediaxml.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
        <action
            android:id="@+id/action_home_to_language"
            app:destination="@id/languageFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="com.example.songpediaxml.DetailFragment"
        android:label="Detail" />

    <fragment
        android:id="@+id/languageFragment"
        android:name="com.example.songpediaxml.LanguageFragment"
        android:label="Language" />

</navigation>