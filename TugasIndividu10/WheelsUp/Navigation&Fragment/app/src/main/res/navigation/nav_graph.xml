<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/firstFragment">

    <fragment
        android:id="@+id/firstFragment"
        android:name="com.example.navigationandfragment.FirstFragment">
        <action
            android:id="@+id/action_firstFragment_to_secondFragment"
            app:destination="@id/secondFragment" />
        <action
            android:id="@+id/action_firstFragment_to_sixthFragment"
            app:destination="@id/sixthFragment" />
    </fragment>

    <fragment
        android:id="@+id/secondFragment"
        android:name="com.example.navigationandfragment.SecondFragment">
        <action
            android:id="@+id/action_secondFragment_to_thirdFragment"
            app:destination="@id/thirdFragment" />
    </fragment>

    <fragment
        android:id="@+id/thirdFragment"
        android:name="com.example.navigationandfragment.ThirdFragment">
        <action
            android:id="@+id/action_thirdFragment_to_fourthFragment"
            app:destination="@id/fourthFragment" />
    </fragment>

    <fragment
        android:id="@+id/fourthFragment"
        android:name="com.example.navigationandfragment.FourthFragment">
        <action
            android:id="@+id/action_fourthFragment_to_fifthFragment"
            app:destination="@id/fifthFragment" />
    </fragment>

    <fragment
        android:id="@+id/fifthFragment"
        android:name="com.example.navigationandfragment.FifthFragment">
        <action
            android:id="@+id/action_fifthFragment_to_sixthFragment"
            app:destination="@id/sixthFragment" />
    </fragment>

    <fragment
        android:id="@+id/sixthFragment"
        android:name="com.example.navigationandfragment.SixthFragment">
        <argument
            android:name="message"
            app:argType="string" />
        <action
            android:id="@+id/action_sixthFragment_to_seventhFragment"
            app:destination="@id/seventhFragment" />
    </fragment>

    <fragment
        android:id="@+id/seventhFragment"
        android:name="com.example.navigationandfragment.SeventhFragment">
        <action
            android:id="@+id/action_seventhFragment_to_eighthFragment"
            app:destination="@id/eighthFragment" />
    </fragment>

    <fragment
        android:id="@+id/eighthFragment"
        android:name="com.example.navigationandfragment.EighthFragment">
        <action
            android:id="@+id/action_eighthFragment_to_ninthFragment"
            app:destination="@id/ninthFragment" />
    </fragment>

    <fragment
        android:id="@+id/ninthFragment"
        android:name="com.example.navigationandfragment.NinthFragment">
        <action
            android:id="@+id/action_ninthFragment_to_tenthFragment"
            app:destination="@id/tenthFragment" />
    </fragment>

    <fragment
        android:id="@+id/tenthFragment"
        android:name="com.example.navigationandfragment.TenthFragment">
        <action
            android:id="@+id/action_tenthFragment_to_firstFragment"
            app:destination="@id/firstFragment" />
    </fragment>

</navigation>